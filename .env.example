# LiteLLM model string — examples:
#   openai/gpt-5-nano
#   anthropic/claude-haiku-4-5-20251001
#   groq/llama-3.3-70b-versatile
#   ollama/qwen2.5
LLM_MODEL=openai/gpt-5-nano

# API key for your chosen provider
LLM_API_KEY=sk-...

# Base URL — only needed for Ollama or custom endpoints
# LLM_BASE_URL=http://localhost:11434

# Vision model — must support image input
VISION_MODEL=openai/gpt-5-nano
# VISION_API_KEY=   # falls back to LLM_API_KEY if blank

# Embedding model
EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_API_KEY=   # falls back to LLM_API_KEY if blank

# Paths
CHROMA_PERSIST_DIR=./chroma_db
SESSION_DB_PATH=./sessions.db

# How many candidates to return per search
MAX_CANDIDATES_RETURNED=5
